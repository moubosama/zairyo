# データベース接続
# ローカル開発: SQLite / 本番: Render Postgres 等の永続DBを推奨（下記README参照）
DATABASE_URL="file:./dev.db"

# AI解析用APIキー（どちらか一方でも動作するが、両方設定でデュアルAI照合が有効になる）
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# JWT署名シークレット（本番では必須。未設定だと起動しない）
# 生成例: openssl rand -base64 48
JWT_SECRET=

# CORS許可オリジン（カンマ区切り）。本番ではフロントのURLを設定
# 例: ALLOWED_ORIGINS=https://zairyo.vercel.app
ALLOWED_ORIGINS=

PORT=8000
