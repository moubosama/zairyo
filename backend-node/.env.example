# データベース接続（PostgreSQL）
# ローカル開発: Docker or Neon無料DB / 本番: Render PostgreSQL
# 例: postgresql://user:password@localhost:5432/zairyo
DATABASE_URL="postgresql://user:password@localhost:5432/zairyo"

# AI解析用APIキー（どちらか一方でも動作するが、両方設定でデュアルAI照合が有効になる）
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_GEMINI_API_KEY=your_gemini_api_key

# 壁記号タイルの読み取り回数（多数決・任意）。デフォルト3=3回読み+過半数採用（読取ブレ対策）、
# 1=従来の1回読み、上限5。回数分だけタイル解析のAPI費用が増える（gemini-2.5-flashで約10円/回）
# WALL_CODE_READS=3

# JWT署名シークレット（本番では必須。未設定だと起動しない）
# 生成例: openssl rand -base64 48
JWT_SECRET=

# CORS許可オリジン（カンマ区切り）。本番ではフロントのURLを設定
# 例: ALLOWED_ORIGINS=https://zairyo.vercel.app
ALLOWED_ORIGINS=

PORT=8000

# 簡易アップロードガード（テスト版の課金露出対策・任意）
# 設定するとuploadに X-Upload-Token ヘッダの一致が必要になる
# フロント側は Vercel の環境変数 VITE_UPLOAD_TOKEN に同じ値を設定
# 生成例: openssl rand -hex 16
UPLOAD_GUARD_TOKEN=

# 会社アカウント登録の招待コード（設定すると登録時に一致必須・任意）
REGISTRATION_CODE=

# 運営者用admin APIのトークン（設定するとadmin APIが有効化・任意）
# 使用: curl -H "X-Admin-Token: <値>" https://<backend>/api/admin/companies
ADMIN_TOKEN=
